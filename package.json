{
  "name": "studbalance",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "build:standalone": "npm run db:template && next build && node scripts/prepare-standalone.js",
    "electron": "electron .",
    "dist": "npm run build:standalone && electron-builder",
    "electron:dev": "electron .",
    "db:template": "node scripts/create-template-db.js"
  },
  "dependencies": {
    "@prisma/client": "^6",
    "exceljs": "^4.4.0",
    "next": "16.2.10",
    "oauth-1.0a": "^2.2.6",
    "prisma": "^6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.axleoid.studbalance",
    "productName": "StudBalance",
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "description": "StudBalance - BrickLink income and expense tracker",
  "author": "Axleoid"
}